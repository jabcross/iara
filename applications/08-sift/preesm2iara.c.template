               «image_width», «image_height»,
               «nOctavesDownN», «totSizeWithoutLayers», «tot_image_size»,
               gpyr, gpyrs, gpyrsUp2x, gpyrsDown2x1, gpyrsDown2xN);
}

void p2iaw_build_dog_pyr(float *gpyr,
                         int *start_octave, int *stop_octave,
                         int *start_layer, int *stop_layer,
                         int *start_line, int *stop_line,
                         int *start_col, int *stop_col,
                         float *dogPyr) {
    build_dog_pyr(«nGpyrLayers», «totSizeWithoutLayers»,
                  «parallelismLevel», «nDogLayers»,
                  «image_width», «image_height», «imgDouble»,
                  gpyr, dogPyr,
                  start_octave, stop_octave,
                  start_layer, stop_layer,
                  start_line, stop_line,
                  start_col, stop_col);
}

void p2iaw_build_grd_rot_pyr(float *gpyr,
                             int *start_octave, int *stop_octave,
                             int *start_layer, int *stop_layer,
                             int *start_line, int *stop_line,
                             int *start_col, int *stop_col,
                             float *grdPyr, float *rotPyr) {
    build_grd_rot_pyr(«nGpyrLayers», «totSizeWithoutLayers»,
                      «parallelismLevel», «nLayers»,
                      «image_width», «image_height», «imgDouble»,
                      gpyr, grdPyr, rotPyr,
                      start_octave, stop_octave,
                      start_layer, stop_layer,
                      start_line, stop_line,
                      start_col, stop_col);
}

/* -- Keypoint detection & extraction ------------------------------------- */

void p2iaw_detect_keypoints(float *dogPyr, float *grdPyr, float *rotPyr,
                            int *start_octave, int *stop_octave,
                            int *start_layer, int *stop_layer,
                            int *start_line, int *stop_line,
                            int *start_col, int *stop_col,
                            struct SiftKeypoint *keypoints) {
    detect_keypoints(«nLayers», «totSizeWithoutLayers»,
                     «parallelismLevel», «nDogLayers», «nLocalKptMax»,
                     «image_width», «image_height»,
                     «nOctaves», «imgDouble»,
                     dogPyr, grdPyr, rotPyr,
                     start_octave, stop_octave,
                     start_layer, stop_layer,
                     start_line, stop_line,
                     start_col, stop_col,
                     keypoints);
}

/* -- INOUT: extract_descriptor ------------------------------------------- */
/* keypoints is inout: Preesm writes descriptors into keypoints_in in-place.
 * Pass NULL for keypoints_out to skip the unnecessary self-memcpy. */

void p2iaw_extract_descriptor(float *grdPyr, float *rotPyr,
                              SiftKpt *keypoints) {
    extract_descriptor(«nLayers», «totSizeWithoutLayers»,
                       «parallelismLevel», «nLocalKptMax»,
                       «image_width», «image_height»,
                       «imgDouble», «nBins», «nHistBins»,
                       «descrWidth», «descrHistBins»,
                       grdPyr, rotPyr,
                       keypoints, NULL);
}

void p2iaw_MERGE_keypoints(SiftKpt *keypoints_in,
                           SiftKpt *keypoints_out, int *nbKeypoints_out) {
    MERGE_keypoints(«nKeypointsMax», «parallelismLevel», «nLocalKptMax»,
                    keypoints_in, keypoints_out, nbKeypoints_out);
}

