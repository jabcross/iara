/**
 * SIFT Preesm-to-IaRa actor wrappers (preesm2iara.c.template)
 *
 * Each p2iaw_<name> wrapper:
 *   - Accepts only data parameters in IaRa order: pure inputs, inout, pure outputs
 *   - Calls the original Preesm C function with config params baked as template markers
 *   - Config params are resolved by instantiate-mlir-template.py at instantiation time
 *
 * Inout pairs (single buffer passed for both Preesm in+out arguments):
 *   - extract_descriptor: keypoints (pass NULL for keypoints_out to skip self-copy)
 *   - BarrierCounterGpyr: iters (pure memcpy identity)
 */

#include <stddef.h>
#include <stdio.h>
#include "ezsift-preesm.h"

/* ── Hextract.pi leaf actors ─────────────────────────────────────────────── */

void p2iaw_read_pgm(unsigned char *img) {
    read_pgm(«image_width», «image_height», img);
}

void p2iaw_draw_keypoints_to_ppm_file(int *nbKeypoints, unsigned char *image,
                                      struct SiftKeypoint *keypoints) {
    draw_keypoints_to_ppm_file(«nKeypointsMax», «image_width», «image_height»,
                               «tot_image_size», nbKeypoints, image, keypoints);
}

void p2iaw_export_keypoints_to_key_file(int *nbKeypoints, SiftKpt *keypoints) {
    export_keypoints_to_key_file(«nKeypointsMax», «DumpDescriptor», «nBins»,
                                 nbKeypoints, keypoints);
    printf("Keypoints found: %d\n", *nbKeypoints);
}

